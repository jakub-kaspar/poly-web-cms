---
layout: layouts/base.njk
permalink: index.html
eleventyComputed:
  meta_title: "{{ homepage.meta_title }}"
  meta_description: "{{ homepage.meta_description }}"
---

  <!-- HERO -->
  <section class="hero">

    <div class="hero__panel hero__panel--left">
      <img src="/hero-1.png" data-i18n-alt="hero.left.img_alt" alt="" />
      <div class="hero__overlay"></div>
      <a href="/halove-vestavby.html" class="hero__tile-link" aria-label="Více o halových vestavbách"></a>
    </div>
    <div class="hero__panel hero__panel--right">
      <img src="/hero-2.png" data-i18n-alt="hero.right.img_alt" alt="" />
      <div class="hero__overlay"></div>
      <a href="/vrata-dvere.html" class="hero__tile-link" aria-label="Více o vratech a dveřích"></a>
    </div>

    <div class="hero__divider"></div>

    <div class="hero__text hero__text--topleft">
      <h2 class="hero__title">Halové<br>vestavby</h2>
      <p class="hero__subtitle" data-i18n="hero.left.subtitle"></p>
      <a href="/halove-vestavby.html" class="hero__btn">
        <span data-i18n="hero.left.btn">Více o vestavbách a konstrukcích</span>
        <svg class="hero__btn-icon" viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="hero__text hero__text--bottomright">
      <h2 class="hero__title">Vrata<br>a dveře</h2>
      <img src="/hormann_logo.png" alt="HÖRMANN" class="hero__title-logo" />
      <p class="hero__subtitle" data-i18n="hero.right.subtitle"></p>
      <a href="/vrata-dvere.html" class="hero__btn">
        <span data-i18n="hero.right.btn">Více o vratech a dveřích</span>
        <svg class="hero__btn-icon" viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="hero__btn--bottomleft">
      <img src="/hero_title_vestavby.svg" alt="" class="hero__title-svg" aria-hidden="true" />
      <a href="/konfigurator.html" target="_blank" rel="noopener" class="hero__btn hero__btn--accent">
        <span class="hero__btn-new" data-i18n="hero.left.btn_new">Novinka</span>
        <span data-i18n="hero.left.btn_configurator">Konfigurátor vestaveb</span>
        <svg class="hero__btn-icon" viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="hero__labels">
      <span data-i18n="hero.label.consulting"></span>
      <span data-i18n="hero.label.management"></span>
      <span data-i18n="hero.label.control"></span>
    </div>
  </section>

  <!-- CLIENTS TICKER -->
  <section class="clients">
    <p class="clients__label" data-i18n="clients.label">Vybraní zákazníci</p>
    <div class="clients__track-wrap">
      <div class="clients__track">
        {% for client in clients %}<span>{{ client }}</span>{% endfor %}
        {% for client in clients %}<span aria-hidden="true">{{ client }}</span>{% endfor %}
      </div>
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section class="about">
    <div class="about__hero">
      <h2 class="about__heading">
        <span>{{ homepage.about_heading_l1 }}</span>
        <span>{{ homepage.about_heading_l2 }}</span>
        <span class="about__heading-accent">{{ homepage.about_heading_l3 }}</span>
      </h2>
      <div class="about__image">
        <img src="/{{ homepage.about_image }}" alt="{{ homepage.about_image_alt }}" />
      </div>
    </div>
    <div class="about__body">
      <p class="about__eyebrow">O nás</p>
      <p class="about__col">{{ homepage.about_col1 }}</p>
      <p class="about__col">{{ homepage.about_col2 }}</p>
      <a href="/o-nas.html" class="about__btn">Náš příběh</a>
    </div>
  </section>

  {% set refs_title = homepage.refs_title %}
  {% include "components/references.njk" %}

  <script src="/main.js?v=4" defer></script>
