<!DOCTYPE html>
<html lang="cs" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ meta_title or "Polymont" }}</title>
  {% if meta_description %}<meta name="description" content="{{ meta_description }}" />{% endif %}
  {% if noindex %}<meta name="robots" content="noindex, follow" />{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,300&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css?v=11" />

</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <a href="/index.html" class="nav__logo" aria-label="Polymont – domů">
      <img src="/polymont_logo_nav_new.png" alt="Polymont" class="nav__logo-img" />
    </a>
    <ul class="nav__links" role="list">
      <li><a href="/halove-vestavby.html" class="nav__link{% if navActive == 'vestavby' %} nav__link--active{% endif %}"{% if navActive == 'vestavby' %} aria-current="page"{% endif %}>Halové vestavby</a></li>
      <li><a href="/vrata-dvere.html"     class="nav__link{% if navActive == 'vrata' %} nav__link--active{% endif %}"{% if navActive == 'vrata' %} aria-current="page"{% endif %}>Vrata a dveře</a></li>
      <li><a href="/o-nas.html"           class="nav__link{% if navActive == 'o-nas' %} nav__link--active{% endif %}"{% if navActive == 'o-nas' %} aria-current="page"{% endif %}>O nás</a></li>
    </ul>
    <a href="/kontakt.html" class="nav__cta{% if navActive == 'kontakt' %} nav__cta--active{% endif %}">
      Kontakt
      <svg viewBox="0 0 16 16" fill="none" width="12" height="12"><path d="M3 8h10M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </nav>

  {{ content | safe }}

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer__top">
      <p class="footer__intro">Sídlo máme v Kutné Hoře. Pro osobní schůzku doporučujeme zavolat předem.</p>
      <a href="/kontakt.html" class="footer__cta">Kontaktujte nás</a>
    </div>
    <div class="footer__body">
      <div class="footer__info">
        <p class="footer__company">{{ settings.company }}</p>
        <div class="footer__block">
          <p>{{ settings.address_street }}</p>
          <p>{{ settings.address_city }}, {{ settings.address_zip }}</p>
        </div>
        <div class="footer__block">
          <a href="tel:{{ settings.phone_href }}" class="footer__link">tel. {{ settings.phone }}</a>
          <a href="mailto:{{ settings.email }}" class="footer__link">{{ settings.email }}</a>
        </div>
        <div class="footer__block footer__block--small">
          <p>IČO: {{ settings.ico }}</p>
        </div>
      </div>
      <div class="footer__map">
        <iframe
          src="https://maps.google.com/maps?q=49.9535837475202,15.288792535489224&hl=cs&z=17&output=embed"
          title="Polymont s.r.o. – {{ settings.address_street }}, {{ settings.address_city }}"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
        <div class="footer__map-overlay">
          <span class="footer__map-label">{{ settings.address_street }}, {{ settings.address_city }}</span>
          <a href="{{ settings.maps_url }}" target="_blank" rel="noopener" class="footer__map-btn">Otevřít v mapách →</a>
        </div>
      </div>
    </div>
    <div class="footer__bottom">
      <p class="footer__copy">© <span id="footer-year"></span> {{ settings.company }}</p>
      <nav class="footer__legal">
        <a href="/ochrana-osobnich-udaju.html"{% if navActive == 'privacy' %} aria-current="page"{% endif %}>Ochrana osobních údajů</a>
      </nav>
    </div>
  </footer>

  <script>
    const y = document.getElementById('footer-year');
    if (y) y.textContent = new Date().getFullYear();
  </script>

  <!-- ── Cookie consent ── -->
  <div id="cookie-banner" class="cookie-banner" hidden aria-live="polite" role="region" aria-label="Souhlas s cookies">
    <div class="cookie-banner__inner">
      <p class="cookie-banner__text">
        Používáme cookies pro analýzu návštěvnosti (Google Analytics), měření výkonu reklam (Google Ads) a analýzu chování uživatelů (Hotjar). Více informací v <a href="/ochrana-osobnich-udaju.html">zásadách ochrany osobních údajů</a>.
      </p>
      <div class="cookie-banner__actions">
        <button id="cookie-decline" class="cookie-banner__btn cookie-banner__btn--secondary" type="button">Odmítnout</button>
        <button id="cookie-accept"  class="cookie-banner__btn cookie-banner__btn--primary"   type="button">Přijmout vše</button>
      </div>
    </div>
  </div>

  <script>
    (function () {
      // ── Replace these IDs with real values before going live ──
      var GA_ID      = 'G-XXXXXXXXXX';   // Google Analytics 4 Measurement ID
      var GADS_ID    = 'AW-XXXXXXXXXX';  // Google Ads Conversion ID
      var HOTJAR_ID  = 0;                // Hotjar Site ID (number)

      var KEY = 'pm_cookie_consent';

      function loadTracking() {
        // Google tag (GA4 + Ads)
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', GA_ID,   { anonymize_ip: true });
        gtag('config', GADS_ID, { anonymize_ip: true });

        // Hotjar
        (function(h,o,t,j,a,r){
          h.hj=h.hj||function(){(h.hj.q=h.hj.q||[]).push(arguments)};
          h._hjSettings={hjid:HOTJAR_ID,hjsv:6};
          a=o.getElementsByTagName('head')[0];
          r=o.createElement('script');r.async=1;
          r.src=t+h._hjSettings.hjid+j+h._hjSettings.hjsv;
          a.appendChild(r);
        })(window,document,'https://static.hotjar.com/c/hotjar-','.js?sv=');
      }

      var consent = localStorage.getItem(KEY);
      if (consent === 'accepted') {
        loadTracking();
      } else if (consent === null) {
        document.getElementById('cookie-banner').hidden = false;
        document.getElementById('cookie-accept').addEventListener('click', function () {
          localStorage.setItem(KEY, 'accepted');
          document.getElementById('cookie-banner').hidden = true;
          loadTracking();
        });
        document.getElementById('cookie-decline').addEventListener('click', function () {
          localStorage.setItem(KEY, 'declined');
          document.getElementById('cookie-banner').hidden = true;
        });
      }
    })();
  </script>

</body>
</html>
